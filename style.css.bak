/* ============================================================
   NOVABEAUTYTT  |  novabeautytt.com.au
   Design system built from the Novabeautytt brand assets:
   deep plum wordmark ink, warm cream paper, forest green and
   chartreuse botanical accents from the logo and business card.
   Mobile-first throughout.
   ============================================================ */

:root{
  /* Palette sampled directly from the Novabeautytt logo and
     business card artwork */
  --bone:   #FAF3E7;   /* page base, warm cream */
  --blush:  #F3E4CD;   /* panel cream, matches logo paper */
  --mauve:  #EBD9BC;   /* deeper panel tone */
  --rose:   #BCD25F;   /* lime botanical accent from the card */
  --rose-soft:#E9D9E2; /* pale plum tint */
  --ink:    #331229;   /* deep plum from the wordmark */
  --ink-soft:#6E4C61;  /* softened plum for secondary text */

  --green:      #2A5B39;  /* forest green from the logo's tt */
  --green-deep: #1E4429;
  --green-text: #2F5F3C;
  --rose-text:  #7C5A2E;  /* warm bronze for small decorative text */
  --lime:       #BCD25F;  /* chartreuse pop from the card back */
  --lime-soft:  #E4ECBE;
  --green-tint: #ECF0DA;

  --font-display:'Playfair Display', Georgia, serif;
  --font-body:'Jost', 'Century Gothic', system-ui, sans-serif;

  --track-wide:.32em;
  --track-mid:.18em;
  --radius:2px;
  --shadow-soft:0 18px 50px -22px rgba(51,18,41,.25);
  --maxw:1160px;
  --pad:clamp(20px, 5vw, 48px);
}

*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  *,*::before,*::after{animation-duration:.001s!important;animation-iteration-count:1!important;transition-duration:.001s!important}
}

body{
  font-family:var(--font-body);
  font-weight:300;
  font-size:16px;
  line-height:1.75;
  color:var(--ink);
  background:var(--bone);
  overflow-x:hidden;
}

img{display:block;max-width:100%;height:auto}
a{color:inherit;text-decoration:none}
ul{list-style:none}
button{font:inherit;cursor:pointer;border:none;background:none;color:inherit}

::selection{background:var(--ink);color:var(--lime)}

:focus-visible{outline:2px solid var(--green);outline-offset:3px}

/* ---------- type ---------- */
h1,h2,h3,.display{
  font-family:var(--font-display);
  font-weight:500;
  line-height:1.14;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--ink);
}
h1{font-size:clamp(2.1rem, 8.5vw, 4.6rem);letter-spacing:clamp(.1em,1.6vw,.3em)}
h2{font-size:clamp(1.7rem, 5.6vw, 3rem)}
h3{font-size:clamp(1.2rem, 3.4vw, 1.5rem)}

.eyebrow{
  font-family:var(--font-body);
  font-size:.72rem;
  font-weight:500;
  letter-spacing:var(--track-wide);
  text-transform:uppercase;
  color:var(--green-text);
  display:block;
  margin-bottom:14px;
}
.lede{font-size:clamp(1rem, 2.6vw, 1.15rem);color:var(--ink-soft);max-width:56ch}

/* ---------- layout primitives ---------- */
.wrap{max-width:var(--maxw);margin:0 auto;padding-left:var(--pad);padding-right:var(--pad)}
.section{padding:clamp(64px,10vw,120px) 0;position:relative}
.section--blush{background:var(--blush)}
.section--ink{background:var(--ink);color:var(--blush)}
.section--ink h2,.section--ink h3{color:var(--blush)}
.center{text-align:center}
.section-head{margin-bottom:clamp(32px,6vw,56px)}
.section-head .lede{margin-top:14px}
.center .lede{margin-left:auto;margin-right:auto}

.z{position:relative;z-index:1}

/* ---------- buttons ---------- */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  font-family:var(--font-body);
  font-size:.78rem;font-weight:500;
  letter-spacing:var(--track-wide);text-transform:uppercase;
  padding:16px 30px;
  border-radius:999px;
  transition:background .25s ease,color .25s ease,transform .2s ease,border-color .25s;
  border:1px solid transparent;
  min-height:48px;
}
.btn--green{background:var(--green);color:#fff}
.btn--green:hover{background:var(--ink);transform:translateY(-2px)}
.btn--ghost{border-color:var(--ink);color:var(--ink)}
.btn--ghost:hover{border-color:var(--green);color:var(--green)}
.btn--ghost-light{border-color:rgba(250,243,231,.6);color:#FAF3E7}
.btn--ghost-light:hover{border-color:var(--lime);background:var(--lime);color:var(--ink)}
.btn--lg{padding:19px 40px;font-size:.82rem}

.text-link{
  font-size:.76rem;font-weight:500;letter-spacing:var(--track-wide);text-transform:uppercase;
  color:var(--green-text);
  border-bottom:1px solid currentColor;padding-bottom:4px;
  transition:color .2s;
}
.text-link:hover{color:var(--green-deep)}

/* ---------- header ---------- */
.header{
  position:sticky;top:0;z-index:100;
  background:rgba(250,243,231,.92);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border-bottom:1px solid rgba(51,18,41,.1);
}
.header__inner{
  display:flex;align-items:center;justify-content:space-between;
  gap:16px;height:68px;
}
.wordmark{display:flex;align-items:center}
.wordmark img{height:34px;width:auto;display:block}
@media (min-width:900px){.wordmark img{height:40px}}
.nav{display:none}
.nav a{
  font-size:.72rem;font-weight:400;letter-spacing:var(--track-mid);text-transform:uppercase;
  padding:8px 2px;position:relative;color:var(--ink-soft);transition:color .2s;
}
.nav a::after{
  content:"";position:absolute;left:0;bottom:2px;width:0;height:2px;
  background:var(--lime);transition:width .25s ease;
}
.nav a:hover,.nav a[aria-current="page"]{color:var(--ink)}
.nav a:hover::after,.nav a[aria-current="page"]::after{width:100%}
.header .btn{padding:11px 22px;min-height:42px}
.header__book{display:none}

.burger{
  position:relative;width:44px;height:44px;margin-right:-8px;
}
.burger span,.burger::before,.burger::after{
  content:"";position:absolute;left:11px;width:22px;height:1.6px;background:var(--ink);
  transition:transform .3s ease,opacity .2s ease,top .3s ease;
}
.burger::before{top:15px}
.burger span{top:21px}
.burger::after{top:27px}
.burger[aria-expanded="true"] span{opacity:0}
.burger[aria-expanded="true"]::before{top:21px;transform:rotate(45deg)}
.burger[aria-expanded="true"]::after{top:21px;transform:rotate(-45deg)}

/* mobile menu */
.mobile-menu{
  position:fixed;inset:68px 0 0 0;z-index:99;
  background:var(--bone);
  display:flex;flex-direction:column;justify-content:space-between;
  padding:8vh var(--pad) 6vh;
  transform:translateY(-8px);opacity:0;visibility:hidden;
  transition:opacity .28s ease,transform .28s ease,visibility .28s;
}
.mobile-menu.is-open{transform:translateY(0);opacity:1;visibility:visible}
.mobile-menu ul{display:flex;flex-direction:column;gap:4px}
.mobile-menu a.mm-link{
  font-family:var(--font-display);
  font-size:clamp(1.7rem,7.5vw,2.4rem);
  letter-spacing:.14em;text-transform:uppercase;
  display:flex;align-items:baseline;gap:14px;
  padding:10px 0;border-bottom:1px solid rgba(51,18,41,.1);
  transition:color .2s,padding-left .2s;
}
.mobile-menu a.mm-link:hover{color:var(--green);padding-left:8px}
.mobile-menu a[aria-current="page"]{color:var(--green)}
.mm-num{font-family:var(--font-body);font-size:.65rem;letter-spacing:.3em;color:var(--rose-text)}
.mobile-menu__foot{display:flex;flex-direction:column;gap:18px}
.mobile-menu__foot .btn{width:100%}
.mm-socials{display:flex;gap:22px;justify-content:center;font-size:.72rem;letter-spacing:var(--track-mid);text-transform:uppercase;color:var(--ink-soft)}

@media (min-width:900px){
  .nav{display:flex;gap:30px}
  .header__book{display:inline-flex}
  .burger,.mobile-menu{display:none}
}

/* ---------- hero ---------- */
.hero{
  position:relative;
  min-height:calc(100svh - 68px);
  display:flex;align-items:flex-end;
  color:var(--bone);
  isolation:isolate;
}
.hero__media{position:absolute;inset:0;z-index:-2;overflow:hidden}
.hero__media img{width:100%;height:100%;object-fit:cover;object-position:center 30%}
.hero::after{
  content:"";position:absolute;inset:0;z-index:-1;
  background:linear-gradient(to top, rgba(35,10,28,.85) 0%, rgba(35,10,28,.3) 45%, rgba(35,10,28,.18) 100%);
}
.hero__inner{width:100%;padding-bottom:clamp(48px,8vw,88px)}
.hero__badge{
  display:inline-flex;align-items:center;gap:10px;
}
.hero__badge svg{width:15px;height:15px;flex:none}
.hero__badge{
  font-size:.68rem;font-weight:600;letter-spacing:var(--track-wide);text-transform:uppercase;
  background:var(--lime);color:var(--ink);
  padding:9px 18px;border-radius:999px;margin-bottom:22px;
}
.hero h1{color:#fff;margin-bottom:14px}
.hero__sub{
  max-width:44ch;color:rgba(255,255,255,.86);
  font-size:clamp(.98rem,2.6vw,1.12rem);margin-bottom:30px;
}
.hero__ctas{display:flex;flex-wrap:wrap;gap:14px}
.hero__meta{
  margin-top:34px;display:flex;flex-wrap:wrap;gap:10px 26px;
  font-size:.7rem;letter-spacing:var(--track-mid);text-transform:uppercase;color:rgba(255,255,255,.8);
}
.hero__meta li{display:flex;align-items:center;gap:8px}
.hero__meta li::before{content:"";width:4px;height:4px;border-radius:50%;background:var(--lime)}

/* ---------- ticker ---------- */
.ticker{
  background:var(--ink);color:var(--lime);
  overflow:hidden;white-space:nowrap;
  padding:13px 0;
}
.ticker__track{display:inline-flex;animation:ticker 30s linear infinite;will-change:transform}
.ticker span{
  font-size:.72rem;font-weight:500;letter-spacing:var(--track-wide);text-transform:uppercase;
  padding:0 26px;display:inline-flex;align-items:center;gap:26px;
}
.ticker span::after{content:"\2740";font-size:.85rem;opacity:.85}
@keyframes ticker{to{transform:translateX(-50%)}}

/* ---------- price panel (signature element) ----------
   Recreates the studio's Instagram price-list system:
   blush panel, hairline vertical rule, right-aligned prices,
   faint serif watermark, floral corner. */
.panel{
  position:relative;
  background:var(--blush);
  padding:clamp(34px,6vw,58px) clamp(22px,5vw,54px);
  overflow:hidden;
  box-shadow:var(--shadow-soft);
}
.panel + .panel{margin-top:clamp(28px,4vw,44px)}
.panel__title{
  text-align:center;margin-bottom:8px;
  font-size:clamp(1.5rem,5vw,2.3rem);letter-spacing:.24em;
}
.panel__note{
  text-align:center;font-size:.85rem;color:var(--ink-soft);
  max-width:52ch;margin:0 auto 26px;
}
.price-group{margin-top:26px}
.price-group h3{
  font-family:var(--font-body);
  font-size:.74rem;font-weight:500;letter-spacing:var(--track-wide);
  color:var(--ink);margin-bottom:14px;text-align:center;
}
.price-row{
  display:flex;align-items:baseline;gap:14px;
  padding:9px 0;
  max-width:560px;margin:0 auto;
}
.price-row .name{flex:1;text-align:right;font-size:.95rem}
.price-row .name small{display:block;font-size:.72rem;letter-spacing:.06em;color:var(--ink-soft)}
.price-row .rule{width:1px;align-self:stretch;background:rgba(51,18,41,.3)}
.price-row .amount{
  width:86px;font-family:var(--font-display);font-size:1.15rem;letter-spacing:.04em;
}
.price-row .amount.acc{color:var(--green-text)}
.price-row--desc{padding:13px 0}
.price-row .desc{
  display:block;font-size:.8rem;line-height:1.55;color:var(--ink-soft);
  margin-top:5px;max-width:40ch;margin-left:auto;
}
.panel__flora{position:absolute;pointer-events:none;opacity:.9}
.panel__flora--br{bottom:-14px;right:-10px;width:clamp(120px,22vw,210px)}
.panel__flora--bl{bottom:-14px;left:-10px;width:clamp(120px,22vw,210px);transform:scaleX(-1)}

.price-legend{
  display:flex;flex-wrap:wrap;justify-content:center;gap:8px 20px;
  margin-top:22px;font-size:.72rem;letter-spacing:.08em;color:var(--ink-soft);
}
.price-legend b{font-weight:500;color:var(--ink)}

/* shape chips */
.chips{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-top:8px}
.chip{
  font-size:.7rem;font-weight:400;letter-spacing:var(--track-mid);text-transform:uppercase;
  border:1px solid rgba(51,18,41,.32);border-radius:999px;
  padding:8px 18px;transition:all .2s;
}
.chip:hover{border-color:var(--green);color:var(--green)}

/* ---------- cards / signatures ---------- */
.grid-2{display:grid;gap:clamp(24px,4vw,40px)}
.grid-3{display:grid;gap:clamp(20px,3vw,28px)}
@media (min-width:720px){
  .grid-2{grid-template-columns:1fr 1fr}
  .grid-3{grid-template-columns:repeat(3,1fr)}
}

.sig-card{
  position:relative;display:block;overflow:hidden;background:var(--mauve);
}
.sig-card img{
  aspect-ratio:4/5;width:100%;object-fit:cover;
  transition:transform .7s cubic-bezier(.2,.6,.2,1);
}
.sig-card:hover img{transform:scale(1.045)}
.sig-card__body{
  position:absolute;inset:auto 0 0 0;
  padding:22px 20px;
  background:linear-gradient(to top, rgba(35,10,28,.82), transparent);
  color:#fff;
}
.sig-card__tag{
  display:inline-block;font-size:.64rem;font-weight:600;letter-spacing:var(--track-wide);
  text-transform:uppercase;background:var(--lime);color:var(--ink);padding:5px 12px;border-radius:999px;margin-bottom:10px;
}
.sig-card h3{color:#fff;letter-spacing:.14em;font-size:1.25rem}
.sig-card p{font-size:.82rem;color:rgba(255,255,255,.82);margin-top:4px}
.sig-card .from{font-family:var(--font-display);font-size:1rem;margin-top:8px;color:var(--lime)}

/* ---------- gallery ---------- */
.filters{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-bottom:clamp(26px,5vw,40px)}
.filter-btn{
  font-size:.7rem;font-weight:500;letter-spacing:var(--track-wide);text-transform:uppercase;
  padding:11px 24px;border-radius:999px;border:1px solid rgba(51,18,41,.3);
  transition:all .22s;min-height:42px;
}
.filter-btn:hover{border-color:var(--green);color:var(--green)}
.filter-btn.is-active{background:var(--green);border-color:var(--green);color:#fff}

.masonry{columns:2;column-gap:12px}
@media (min-width:720px){.masonry{columns:3;column-gap:16px}}
.masonry__item{
  break-inside:avoid;margin-bottom:12px;position:relative;overflow:hidden;
  display:block;width:100%;
}
@media (min-width:720px){.masonry__item{margin-bottom:16px}}
.masonry__item img{width:100%;transition:transform .6s ease,filter .4s}
.masonry__item::after{
  content:"";position:absolute;inset:0;background:var(--ink);
  opacity:0;transition:opacity .3s;mix-blend-mode:multiply;
}
.masonry__item:hover img{transform:scale(1.04)}
.masonry__item:hover::after{opacity:.22}
.masonry__item.is-hidden{display:none}

/* lightbox */
.lightbox{
  position:fixed;inset:0;z-index:200;background:rgba(35,10,28,.95);
  display:none;align-items:center;justify-content:center;padding:20px;
}
.lightbox.is-open{display:flex}
.lightbox img{max-width:100%;max-height:86vh;box-shadow:0 30px 80px rgba(0,0,0,.5)}
.lightbox__close{
  position:absolute;top:18px;right:18px;color:#fff;
  font-size:.8rem;letter-spacing:var(--track-wide);text-transform:uppercase;
  padding:12px 16px;
}
.lightbox__nav{
  position:absolute;top:50%;transform:translateY(-50%);
  color:#fff;font-size:1.6rem;padding:16px;font-family:var(--font-display);
}
.lightbox__nav--prev{left:6px}
.lightbox__nav--next{right:6px}

/* ---------- split feature ---------- */
.split{display:grid;gap:clamp(28px,5vw,64px);align-items:center}
@media (min-width:840px){
  .split{grid-template-columns:1fr 1fr}
  .split--flip > :first-child{order:2}
}
.split__media{position:relative}
.split__media img{width:100%;aspect-ratio:4/5;object-fit:cover;box-shadow:var(--shadow-soft)}
.split__media .frame{
  position:absolute;inset:14px;border:1px solid rgba(244,240,239,.65);pointer-events:none;
}
.split__media--offset::before{
  content:"";position:absolute;top:-16px;left:-16px;right:16px;bottom:16px;
  background:var(--lime-soft);z-index:-1;
}
.split__body h2{margin-bottom:18px}
.split__body p + p{margin-top:14px}
.split__body .btn{margin-top:28px}

.ticks{margin-top:22px;display:flex;flex-direction:column;gap:12px}
.ticks li{display:flex;gap:14px;align-items:flex-start;font-size:.95rem}
.ticks li::before{
  content:"\2713";flex:none;width:22px;height:22px;border-radius:50%;
  background:var(--green);color:#fff;font-size:.68rem;
  display:grid;place-items:center;margin-top:4px;
}

/* ---------- policy / faq ---------- */
.acc-item{border-bottom:1px solid rgba(51,18,41,.16)}
.acc-item summary{
  list-style:none;cursor:pointer;
  display:flex;justify-content:space-between;align-items:center;gap:18px;
  padding:22px 0;
  font-family:var(--font-display);font-size:clamp(1.05rem,3vw,1.3rem);
  letter-spacing:.1em;text-transform:uppercase;
}
.acc-item summary::-webkit-details-marker{display:none}
.acc-item summary .ind{
  flex:none;width:30px;height:30px;border-radius:50%;
  border:1px solid rgba(51,18,41,.32);
  display:grid;place-items:center;
  font-family:var(--font-body);font-size:1rem;font-weight:300;
  transition:all .25s;
}
.acc-item[open] summary .ind{background:var(--green);border-color:var(--green);color:#fff;transform:rotate(45deg)}
.acc-item .acc-body{padding:0 0 26px;color:var(--ink-soft);max-width:64ch}
.acc-body p + p{margin-top:12px}
.acc-body strong{font-weight:500;color:var(--ink)}

.notice{
  background:var(--green-tint);border-left:3px solid var(--green);
  padding:20px 24px;margin-top:30px;font-size:.92rem;
}

/* ---------- steps ---------- */
.steps{display:grid;gap:18px;counter-reset:step}
@media (min-width:760px){.steps{grid-template-columns:repeat(3,1fr)}}
.step{
  counter-increment:step;background:var(--bone);padding:30px 26px;position:relative;
  box-shadow:var(--shadow-soft);
}
.step::before{
  content:"Step " counter(step);
  display:block;font-size:.66rem;font-weight:500;letter-spacing:var(--track-wide);
  text-transform:uppercase;color:var(--green);margin-bottom:12px;
}
.step h3{font-size:1.1rem;letter-spacing:.12em;margin-bottom:10px}
.step p{font-size:.9rem;color:var(--ink-soft)}

/* ---------- booking ---------- */
.book-hero{background:var(--blush)}
.fresha-slot{
  margin-top:clamp(30px,5vw,48px);
  background:var(--bone);box-shadow:var(--shadow-soft);
  padding:clamp(30px,5vw,50px);text-align:center;position:relative;overflow:hidden;
}
.fresha-slot iframe{width:100%;min-height:640px;border:0;background:#fff}

/* ---------- contact ---------- */
.contact-list{display:grid;gap:14px;margin-top:26px}
.contact-list a,.contact-list div{
  display:flex;align-items:center;gap:16px;
  padding:20px 22px;background:var(--bone);box-shadow:var(--shadow-soft);
  font-size:.95rem;transition:transform .2s;
}
.contact-list a:hover{transform:translateY(-2px)}
.contact-list .ic svg{width:18px;height:18px}
.contact-list .ic{
  flex:none;width:40px;height:40px;border-radius:50%;
  background:var(--green-tint);color:var(--green);
  display:grid;place-items:center;font-size:.9rem;
}
.contact-list small{display:block;font-size:.68rem;letter-spacing:var(--track-mid);text-transform:uppercase;color:var(--ink-soft)}

/* ---------- instagram band ---------- */
.ig-band a.ig-cell{display:block;overflow:hidden;position:relative}
.ig-band img{aspect-ratio:1/1;object-fit:cover;width:100%;transition:transform .5s}
.ig-band a.ig-cell:hover img{transform:scale(1.06)}
.ig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
@media (min-width:760px){.ig-grid{grid-template-columns:repeat(6,1fr)}}

/* ---------- CTA band ---------- */
.cta-band{
  position:relative;overflow:hidden;text-align:center;
  background:var(--ink);color:var(--blush);
  padding:clamp(72px,12vw,130px) 0;
}
.cta-band h2{color:var(--blush);margin-bottom:16px}
.cta-band .lede{color:rgba(243,228,205,.78);margin:0 auto 34px}

/* ---------- footer ---------- */
.footer{background:var(--ink);color:rgba(243,228,205,.82);padding:60px 0 34px;font-size:.85rem}
.footer .wordmark{display:inline-block;margin-bottom:14px}
.footer .wordmark img{height:38px;width:auto}
.footer__grid{display:grid;gap:36px;margin-bottom:44px}
@media (min-width:760px){.footer__grid{grid-template-columns:1.4fr 1fr 1fr}}
.footer h4{
  font-size:.68rem;font-weight:600;letter-spacing:var(--track-wide);text-transform:uppercase;
  color:var(--lime);margin-bottom:16px;
}
.footer ul{display:flex;flex-direction:column;gap:9px}
.footer a{transition:color .2s}
.footer a:hover{color:#fff}
.footer__bar{
  border-top:1px solid rgba(243,228,205,.16);padding-top:26px;
  display:flex;flex-wrap:wrap;gap:10px 24px;justify-content:space-between;
  font-size:.72rem;letter-spacing:.06em;color:rgba(243,228,205,.66);
}

/* ---------- floating book button (mobile) ---------- */
.fab-book{
  position:fixed;left:16px;right:16px;bottom:16px;z-index:90;
  display:flex;
  transform:translateY(120%);transition:transform .35s ease;
}
.fab-book.is-visible{transform:translateY(0)}
.fab-book .btn{width:100%;box-shadow:0 14px 34px -8px rgba(30,68,41,.55)}
@media (min-width:900px){.fab-book{display:none}}

/* ---------- reveal ---------- */
html.js .reveal{opacity:0;transform:translateY(26px);transition:opacity .7s ease,transform .7s ease}
html.js .reveal.is-in{opacity:1;transform:none}

/* ---------- flora svg tint ---------- */
.flora-line{color:var(--lime)}

/* ---------- misc ---------- */
.divider-flora{
  display:flex;align-items:center;gap:18px;justify-content:center;
  margin:clamp(40px,7vw,64px) auto;max-width:520px;
}
.divider-flora::before,.divider-flora::after{content:"";height:1px;flex:1;background:rgba(51,18,41,.2)}
.divider-flora svg{width:26px;height:26px;color:var(--green)}

.skip-link{
  position:absolute;left:-9999px;top:0;background:var(--green);color:#fff;
  padding:12px 20px;z-index:999;font-size:.8rem;letter-spacing:.1em;
}
.skip-link:focus{left:0}

.about-slot{
  border:1px dashed rgba(51,18,41,.35);
  padding:clamp(28px,5vw,44px);
  background:rgba(255,255,255,.4);
  color:var(--ink-soft);font-size:.92rem;
  min-height:220px;display:flex;align-items:center;justify-content:center;text-align:center;
}
